{
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/webhook",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/notify",
      "schedule": "0 0 * * *"
    }
  ]
}
